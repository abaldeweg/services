{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/types",
    "composite": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.stories.*",
  ]
}
