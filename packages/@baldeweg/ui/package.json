    "vue": "3.5.38",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/vue3-vite": "10.4.6",
    "@tailwindcss/vite": "4.2.4",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.3",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.5.0",
    "jsdom": "29.1.1",
    "knip": "6.20.0",
    "prettier": "3.8.4",
    "storybook": "10.4.6",
    "storybook-addon-tag-badges": "3.1.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-vue-devtools": "8.1.3",
    "vite-plugin-webfont-dl": "3.12.0",
    "vitest": "4.1.9",
    "vue": "3.5.38",
    "vue-router": "5.0.7",
    "vue-tsc": "3.3.5"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/ui.es.js",
